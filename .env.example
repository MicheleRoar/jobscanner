# Copy this file to ".env" (without .example) and fill in the values.
# The .env file must NOT be shared with anyone: it contains your email password.

# SMTP server of your email provider.
# For Gmail: smtp.gmail.com, port 587, and you need an "app password"
# (not your regular password) generated at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.address@gmail.com
SMTP_PASS=your-app-password

# Where the email appears to come from (usually the same as SMTP_USER)
EMAIL_FROM=your.address@gmail.com
# Who to send it to
EMAIL_TO=you@example.com

# Time of the daily scan, HH:MM format (container time, usually UTC)
SCAN_TIME=07:00

# If true, also runs a scan immediately when the container starts
RUN_ON_STARTUP=true
